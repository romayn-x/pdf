{
  "name": "pdf-watermark-react",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "electron:dev": "pnpm build && electron .",
    "dist:exe": "pnpm build && electron-builder --win nsis",
    "dist:portable": "pnpm build && electron-builder --win portable"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.2",
    "@cloudbase/js-sdk": "^3.3.11",
    "@vitejs/plugin-react": "^4.3.4",
    "antd": "^5.23.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.local.pdfwatermark",
    "productName": "PDF水印工具",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-builder",
      "esbuild"
    ]
  }
}
